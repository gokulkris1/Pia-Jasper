# Example environment variables for local MCP stdio demo
# Base URL for Cisco Jasper Control Center (no trailing slash)
CC_BASE_URL=https://example.jasper.com

# Full Bearer token string, e.g. "Bearer eyJ..."
CC_JASPER_BEARER=Bearer eyJhbGciOi...

# Optional: comma-separated allowed account IDs. If empty, no allowlist enforced.
CC_ALLOWED_ACCOUNT_IDS=12345,67890

# Phase 1 operation workflow mode. Use "stub" for local plumbing demos and "live" when the Jasper rate-plan adapter is wired.
PIA_JASPER_MODE=stub

# Where operation previews, results, and pending confirmations are stored.
PIA_JASPER_ARTIFACT_DIR=.pia_jasper

# Optional path to stub inventory used in stub mode.
PIA_JASPER_STUB_DATA=pia_jasper_mcp/stub_devices.sample.json

# Safety limit for maximum identifiers in one operation.
PIA_JASPER_MAX_BATCH=100
