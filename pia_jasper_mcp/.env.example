# Example environment variables
# Base URL for Cisco Jasper Control Center (no trailing slash)
CC_BASE_URL=https://example.jasper.com

# Full Bearer token string, e.g. "Bearer eyJ..."
CC_JASPER_BEARER=Bearer eyJhbGciOi...

# Optional: comma-separated allowed account IDs. If empty, no allowlist enforced.
CC_ALLOWED_ACCOUNT_IDS=12345,67890

# Optional: protect endpoints with this token. If set, requests must include
# Authorization: Bearer <MCP_AUTH_TOKEN>
MCP_AUTH_TOKEN=

# Optional CORS support
ENABLE_CORS=false
# If ENABLE_CORS=true, set CORS_ORIGINS to comma-separated origins, or leave empty for '*'
CORS_ORIGINS=
