# MVP Ops Executor parser mode: rule (default) or llm (falls back to rule in this MVP)
PARSER_MODE=rule

# Connector selection: mock (default), jasper, or auto
CONNECTOR_MODE=mock

# SQLite database path for audit logs
MVP_DB_PATH=./mvp_ops_executor/mvp_ops_executor.db

# Jasper placeholders for later integration (JasperConnector is a stub in this MVP)
JASPER_BASE_URL=
JASPER_API_TOKEN=

